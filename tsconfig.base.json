{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "noImplicitThis": true,
    "alwaysStrict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "moduleResolution": "node",
    "allowSyntheticDefaultImports": true,
    "baseUrl": ".",
    "paths": {
      "@modules/shared": ["modules/shared/src/index.ts"],
      "@modules/shared/*": ["modules/shared/src/*"],
      "@modules/lead": ["modules/lead/src/index.ts"],
      "@modules/lead/*": ["modules/lead/src/*"],
      "@modules/enrichment": ["modules/enrichment/src/index.ts"],
      "@modules/enrichment/*": ["modules/enrichment/src/*"],
      "@modules/extraction": ["modules/extraction/src/index.ts"],
      "@modules/extraction/*": ["modules/extraction/src/*"],
      "@modules/mock-api": ["modules/mock-api/src/index.ts"],
      "@modules/mock-api/*": ["modules/mock-api/src/*"],
      "@test/*": ["test/*"]
    }
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
